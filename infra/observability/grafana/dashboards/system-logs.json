{
  "title": "System Logs",
  "timezone": "browser",
  "schemaVersion": 39,
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": { "type": "loki", "uid": "Loki" },
        "query": "label_values(compose_service)",
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" },
        "refresh": 2
      },
      {
        "name": "level",
        "type": "query",
        "datasource": { "type": "loki", "uid": "Loki" },
        "query": "label_values(level)",
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" },
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "title": "Log Volume by Service",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "Loki" },
          "expr": "sum(rate({compose_service=~\"$service\"}[1m])) by (compose_service)"
        }
      ]
    },
    {
      "title": "Error Rate by Service",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "Loki" },
          "expr": "sum(rate({compose_service=~\"$service\", level=\"error\"}[1m])) by (compose_service)"
        }
      ]
    },
    {
      "title": "All Logs",
      "type": "logs",
      "gridPos": { "h": 16, "w": 24, "x": 0, "y": 8 },
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none",
        "enableLogDetails": true
      },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "Loki" },
          "expr": "{compose_service=~\"$service\", level=~\"$level\"}"
        }
      ]
    }
  ]
}